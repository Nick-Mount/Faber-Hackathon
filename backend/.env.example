# Postgres connection string.
# Local: postgresql://user:pass@localhost:5432/roomstylist
# Cloud Run + Cloud SQL: postgresql://user:pass@/roomstylist?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Firebase project ID — used by firebase-admin to verify ID tokens.
# If running outside GCP, also set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path.
FIREBASE_PROJECT_ID=

# Comma-separated allowed origins for CORS (frontend dev + prod).
ALLOWED_ORIGINS=http://localhost:5173

PORT=3000
